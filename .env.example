# ── Gemini AI (post generation) ──────────────────────────────────────────────
# Get keys: https://aistudio.google.com/apikey
# GEMINI_API_KEY_2 is optional — auto-used when primary hits daily quota
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY_2=your_second_gemini_api_key_here

# Optional: override model (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# ── Euron fallback (used when ALL Gemini keys are exhausted) ──────────────────
# Get key: https://euron.one
EURON_API_KEY=your_euron_api_key_here

# ── Exa (real-time neural web research) ──────────────────────────────────────
# Get key: https://exa.ai → Dashboard → API Keys
EXA_API_KEY=your_exa_api_key_here

# ── LinkedIn (posts directly — no Buffer needed) ──────────────────────────────
# From your LinkedIn App: https://developer.linkedin.com → your app → Auth tab
LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here
# Run once to get these:  python scripts/get_linkedin_token.py
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token_here
LINKEDIN_PERSON_ID=your_linkedin_person_id_here

# ── Infographic settings ──────────────────────────────────────────────────────
# Handle shown at the bottom of every infographic
INFOGRAPHIC_HANDLE=@YourHandle
# Set to "0" to disable infographic generation (posts text-only)
INCLUDE_INFOGRAPHIC=1

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700;800&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { width: 1080px; overflow: hidden; }

  :root {
    --bg:     #0b0f1a;
    --panel:  #131a2b;
    --accent: #34e7a1;
    --white:  #f5f7fa;
    --slate:  #8b96a8;
    --line:   rgba(255,255,255,0.09);
  }

  .page {
    width: 1080px; height: 1350px;
    background: var(--bg);
    position: relative; overflow: hidden;
    font-family: 'Inter', sans-serif;
  }

  /* subtle grid texture */
  .grid-bg {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(var(--line) 1px, transparent 1px),
      linear-gradient(90deg, var(--line) 1px, transparent 1px);
    background-size: 54px 54px;
    opacity: 0.5;
    mask-image: linear-gradient(to bottom, black, black 70%, transparent 100%);
  }

  .content { position: absolute; left: 64px; top: 0; right: 64px; bottom: 0; }

  /* ── eyebrow tag ── */
  .eyebrow {
    position: absolute; left: 0; top: 56px;
    display: flex; align-items: center; gap: 10px;
  }
  .eyebrow-dot { width: 10px; height: 10px; border-radius: 50%; background: var(--accent); box-shadow: 0 0 12px var(--accent); }
  .eyebrow span {
    font-family: 'JetBrains Mono', monospace; font-weight: 500; font-size: 21px;
    color: var(--accent); letter-spacing: 0.5px;
  }

  /* ── headline ── */
  .headline { position: absolute; left: 0; top: 96px; width: 952px; }
  .h-line {
    font-family: 'Space Grotesk', sans-serif; font-weight: 800; font-size: 68px;
    line-height: 1.08; letter-spacing: -0.5px;
  }
  .h-line.l1 { color: var(--white); }
  .h-line.l2 { color: var(--accent); }

  /* ── hook / terminal comment ── */
  .hook-row { position: absolute; left: 0; top: 0; width: 952px; display: flex; gap: 10px; align-items: flex-start; }
  .hook-row .bar { color: var(--slate); font-family: 'JetBrains Mono', monospace; font-size: 22px; flex-shrink: 0; }
  .hook-text {
    font-family: 'JetBrains Mono', monospace; font-weight: 400; font-size: 22px;
    color: var(--slate); line-height: 1.45;
  }

  .hr { position: absolute; left: 0; width: 952px; height: 1px; background: var(--line); }

  /* ── step rows ── */
  .step { position: absolute; left: 0; width: 952px; }
  .step-inner { display: flex; gap: 26px; align-items: flex-start; position: relative; padding-left: 20px; }
  .step-bar { position: absolute; left: 0; top: 4px; bottom: 10px; width: 4px; border-radius: 3px; background: var(--accent); }
  .step-num {
    font-family: 'Space Grotesk', sans-serif; font-weight: 800; font-size: 46px;
    color: var(--accent); width: 92px; flex-shrink: 0; line-height: 1;
  }
  .step-title {
    font-family: 'Space Grotesk', sans-serif; font-weight: 700; font-size: 32px;
    color: var(--white); margin-bottom: 12px; letter-spacing: 0.2px;
  }
  .pills { display: flex; flex-wrap: wrap; gap: 8px; }
  .pill {
    font-family: 'Inter', sans-serif; font-weight: 500; font-size: 18px;
    color: var(--slate); background: var(--panel); border: 1px solid var(--line);
    border-radius: 8px; padding: 6px 12px; white-space: nowrap;
  }

  /* ── footer ── */
  .footer { position: absolute; left: 0; bottom: 54px; width: 952px; }
  .footer-tag {
    font-family: 'Inter', sans-serif; font-weight: 500; font-size: 20px;
    color: var(--slate);
  }

  /* corner mark */
  .corner-mark {
    position: absolute; right: 0; top: 60px;
    font-family: 'JetBrains Mono', monospace; font-weight: 700; font-size: 24px;
    color: var(--slate); border: 1.5px solid var(--line); border-radius: 8px;
    padding: 8px 14px;
  }
</style>
</head>
<body>
<div class="page">
  <div class="grid-bg"></div>

  <div class="content">

    <!-- eyebrow -->
    <div class="eyebrow">
      <div class="eyebrow-dot"></div>
      <span>AI SYSTEMS // DAILY NOTES</span>
    </div>

    <!-- corner mark -->
    <div class="corner-mark">&lt;/&gt;</div>

    <!-- headline -->
    <div class="headline">
      <div id="h1" class="h-line l1">{{ title_line1 }}</div>
      <div id="h2" class="h-line l2">{{ title_line2 }}</div>
    </div>

    <!-- hook (terminal-comment style), positioned by JS below headline -->
    <div class="hook-row" id="hookRow">
      <span class="bar">//</span>
      <span class="hook-text" id="hookText">{{ hook }}</span>
    </div>

    <div class="hr" id="hr1"></div>

    <!-- Step rows: box1..box5 rendered as a sequential 1-5 vertical flow -->
    {% set steps = [box1, box2, box3, box4, box5] %}
    {% for b in steps %}
    <div class="step" id="step{{ loop.index }}">
      <div class="step-inner">
        <div class="step-bar"></div>
        <div class="step-num">{{ '%02d' % loop.index }}</div>
        <div>
          <div class="step-title">{{ b.label }}</div>
          <div class="pills">{% for p in b.points %}<div class="pill">{{ p }}</div>{% endfor %}</div>
        </div>
      </div>
    </div>
    {% endfor %}

    <!-- Footer -->
    <div class="footer">
      <div class="footer-tag">Daily notes on the tech behind AI — systems, models, infra</div>
    </div>

  </div>
</div>

<script>
window._infoDone = false;

window.drawInfographic = function() {
  if (window._infoDone) return;
  window._infoDone = true;

  // ── Shrink headline lines if too wide ──
  ['h1','h2'].forEach(function(id) {
    var el = document.getElementById(id);
    if (!el) return;
    var sz = parseFloat(getComputedStyle(el).fontSize);
    while (el.scrollWidth > 952 && sz > 34) { sz--; el.style.fontSize = sz + 'px'; }
  });

  // ── Shrink step titles if too wide ──
  document.querySelectorAll('.step-title').forEach(function(el) {
    var sz = parseFloat(getComputedStyle(el).fontSize);
    while (el.scrollWidth > 800 && sz > 20) { sz--; el.style.fontSize = sz + 'px'; }
  });

  var pr       = document.querySelector('.page').getBoundingClientRect();
  var headline = document.querySelector('.headline');
  var hookRow  = document.getElementById('hookRow');
  var hr1      = document.getElementById('hr1');

  // ── Position hook row right under the headline ──
  var hH = headline.getBoundingClientRect().height;
  var headlineTop = 96;
  var hookTop = headlineTop + hH + 22;
  hookRow.style.top = hookTop + 'px';

  var hookH = hookRow.getBoundingClientRect().height;
  var hrTop = hookTop + hookH + 30;
  hr1.style.top = hrTop + 'px';

  // ── Distribute the 5 step rows evenly across the space between the divider
  //     and the footer, so the layout always fills the canvas regardless of
  //     how much text each step wraps to. ──
  var steps = [];
  var totalH = 0;
  for (var i = 1; i <= 5; i++) {
    var el = document.getElementById('step' + i);
    var h = el.getBoundingClientRect().height;
    steps.push({ el: el, h: h });
    totalH += h;
  }

  var footerEl  = document.querySelector('.footer');
  var footerTop = footerEl.getBoundingClientRect().top - pr.top;
  var startY    = hrTop + 44;
  var endY      = footerTop - 50;
  var gapCount  = steps.length - 1;
  var gap       = Math.max(34, (endY - startY - totalH) / gapCount);

  var y = startY;
  for (var j = 0; j < steps.length; j++) {
    steps[j].el.style.top = y + 'px';
    y += steps[j].h + gap;
    if (j < steps.length - 1) {
      var div = document.createElement('div');
      div.className = 'hr';
      div.style.top = (y - gap / 2) + 'px';
      document.querySelector('.content').appendChild(div);
    }
  }
};

document.fonts.ready.then(function() { window.drawInfographic(); });
</script>
</body>
</html>

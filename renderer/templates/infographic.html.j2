<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;600;700&display=swap" rel="stylesheet">
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { width: 900px; overflow: hidden; }

  .page {
    width: 900px;
    height: 900px;
    background-color: #f6f0d2;
    background-image: repeating-linear-gradient(
      to bottom,
      transparent 0px, transparent 30px,
      #9ab8d6 30px, #9ab8d6 31px
    );
    font-family: 'Caveat', 'Comic Sans MS', cursive;
    position: relative;
    padding: 28px 38px 22px 72px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  /* ── Spiral binding ── */
  .spiral-line {
    position: absolute; left: 52px; top: 0; bottom: 0;
    width: 2px; background: #5a5050; opacity: 0.35;
  }
  .spiral { position: absolute; left: 24px; top: 22px; bottom: 22px; width: 56px; }
  .ring {
    position: absolute; left: 0;
    width: 42px; height: 20px;
    border: 4px solid #5a5050;
    border-radius: 50%;
    border-bottom-color: transparent;
    border-left-color: transparent;
    transform: rotate(-20deg);
  }

  /* ── Header ── */
  .header {
    display: flex; align-items: flex-start;
    gap: 14px; margin-bottom: 14px; position: relative;
  }
  .logo-box {
    width: 58px; height: 58px;
    border: 3px solid #111;
    display: flex; align-items: center; justify-content: center;
    font-size: 20px; font-weight: 700; color: #111;
    flex-shrink: 0; letter-spacing: -0.5px;
  }
  .title-wrap { flex: 1; }
  .t1 {
    font-size: 35px; font-weight: 700; color: #111;
    text-transform: uppercase; line-height: 1.0; letter-spacing: 0.5px;
  }
  .t2 {
    font-size: 35px; font-weight: 700; color: #1a6cbf;
    text-transform: uppercase; line-height: 1.05; letter-spacing: 0.5px;
  }

  /* ── Divider ── */
  .divider { height: 2.5px; background: #111; border-radius: 1px; margin-bottom: 14px; }

  /* ── 5-box grid (stretches to fill remaining space) ── */
  .grid {
    display: grid;
    grid-template-columns: 1fr 70px 1fr;
    grid-template-rows: 1fr 52px 1fr;
    flex: 1;
    margin-bottom: 12px;
    min-height: 0;
  }

  .box {
    border: 3px solid #111; padding: 10px 13px;
    display: flex; flex-direction: column; gap: 4px;
  }
  .box-label {
    font-size: 20px; font-weight: 700; color: #111;
    text-transform: uppercase; line-height: 1.0;
  }
  .box-pts { list-style: none; }
  .box-pts li { font-size: 15.5px; color: #111; line-height: 1.5; }
  .box-pts li::before { content: "• "; }

  /* center (narrow) box */
  .box-c {
    border: 3px solid #111; padding: 8px 7px; margin: 2px;
    display: flex; flex-direction: column; gap: 3px; height: calc(100% - 4px);
  }
  .box-c .box-label { font-size: 15px; text-align: center; }
  .box-c .box-pts li { font-size: 12.5px; line-height: 1.4; }

  /* ── Arrow cells ── */
  .arr-hr { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 5px; }
  .arr-ul { display: flex; align-items: flex-end; justify-content: center; padding-bottom: 4px; }
  .arr-dr { display: flex; align-items: flex-start; justify-content: center; padding-top: 4px; }
  .arr-mid { display: flex; align-items: center; justify-content: center; }

  /* ── Bottom deco row ── */
  .deco-row {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 10px; padding: 0 2px;
  }
  .lines { display: flex; flex-direction: column; gap: 5px; }
  .ln { height: 3px; background: #111; border-radius: 1px; }

  /* ── Quote ── */
  .quote {
    border: 2.5px solid #111; background: #fff9c4;
    padding: 10px 18px; font-size: 17px; color: #111;
    text-align: center; line-height: 1.45; margin-bottom: 8px;
  }
  .quote::before { content: '\201C'; font-size: 28px; font-weight: 700; }
  .quote::after  { content: '\201D'; font-size: 28px; font-weight: 700; }

  /* ── Footer ── */
  .footer { display: flex; align-items: center; justify-content: flex-end; gap: 8px; }
  .fi {
    width: 26px; height: 26px; border: 2.5px solid #111; border-radius: 7px;
    position: relative; flex-shrink: 0;
  }
  .fi::before {
    content: ''; position: absolute; left: 50%; top: 50%;
    transform: translate(-50%,-50%);
    width: 12px; height: 12px; border: 2px solid #111; border-radius: 50%;
  }
  .fi::after {
    content: ''; position: absolute; right: 4px; top: 4px;
    width: 3px; height: 3px; background: #111; border-radius: 50%;
  }
  .handle { font-size: 17px; color: #555; font-style: italic; }

  /* ── Pencil deco ── */
  .pencil { position: absolute; right: 40px; top: 100px; font-size: 28px; opacity: 0.45; transform: rotate(18deg); }
</style>
</head>
<body>
<div class="page">

  <div class="spiral-line"></div>
  <div class="spiral">
    {% for i in range(15) %}<div class="ring" style="top:{{ i*54 }}px"></div>{% endfor %}
  </div>

  <!-- Header -->
  <div class="header">
    <div class="logo-box">AI</div>
    <div class="title-wrap">
      <div class="t1">{{ title_line1 }}</div>
      <div class="t2">{{ title_line2 }}</div>
    </div>
    <svg width="88" height="66" viewBox="0 0 88 66" fill="none" style="flex-shrink:0">
      <rect x="5"  y="50" width="12" height="13" stroke="#111" stroke-width="2"/>
      <rect x="22" y="38" width="12" height="25" stroke="#111" stroke-width="2"/>
      <rect x="39" y="24" width="12" height="39" stroke="#111" stroke-width="2"/>
      <rect x="56" y="12" width="12" height="51" stroke="#111" stroke-width="2"/>
      <path d="M5 55 Q 34 22 74 7" stroke="#111" stroke-width="2.5" stroke-linecap="round" fill="none"/>
      <polygon points="74,7 64,10 68,18" fill="#111"/>
    </svg>
  </div>

  <div class="divider"></div>

  <!-- 5-box grid -->
  <div class="grid">

    <!-- ROW 1 -->
    <div class="box" style="grid-column:1;grid-row:1">
      <div class="box-label">{{ box1.label }}</div>
      <ul class="box-pts">{% for p in box1.points %}<li>{{ p }}</li>{% endfor %}</ul>
    </div>

    <div class="arr-hr" style="grid-column:2;grid-row:1">
      <svg width="60" height="22" viewBox="0 0 60 22" fill="none">
        <line x1="2" y1="11" x2="48" y2="11" stroke="#111" stroke-width="2.5"/>
        <polygon points="48,6 60,11 48,16" fill="#111"/>
      </svg>
      <div style="font-size:28px;margin-top:4px">💡</div>
    </div>

    <div class="box" style="grid-column:3;grid-row:1">
      <div class="box-label">{{ box2.label }}</div>
      <ul class="box-pts">{% for p in box2.points %}<li>{{ p }}</li>{% endfor %}</ul>
      <div style="text-align:right;font-size:22px;opacity:0.45;margin-top:auto">✏️</div>
    </div>

    <!-- ROW 2: arrows -->
    <div class="arr-ul" style="grid-column:1;grid-row:2">
      <svg width="22" height="48" viewBox="0 0 22 48" fill="none">
        <line x1="11" y1="46" x2="11" y2="8" stroke="#111" stroke-width="2.5"/>
        <polygon points="6,8 11,0 16,8" fill="#111"/>
      </svg>
    </div>

    <div class="arr-mid" style="grid-column:2;grid-row:2">
      <svg width="40" height="36" viewBox="0 0 40 36" fill="none">
        <line x1="4" y1="8"  x2="36" y2="8"  stroke="#111" stroke-width="1.4" stroke-dasharray="4,3"/>
        <line x1="4" y1="18" x2="28" y2="18" stroke="#111" stroke-width="1.4" stroke-dasharray="4,3"/>
        <line x1="4" y1="28" x2="18" y2="28" stroke="#111" stroke-width="1.4" stroke-dasharray="4,3"/>
      </svg>
    </div>

    <div class="arr-dr" style="grid-column:3;grid-row:2">
      <svg width="22" height="48" viewBox="0 0 22 48" fill="none">
        <line x1="11" y1="2" x2="11" y2="40" stroke="#111" stroke-width="2.5"/>
        <polygon points="6,40 11,48 16,40" fill="#111"/>
      </svg>
    </div>

    <!-- ROW 3 -->
    <div class="box" style="grid-column:1;grid-row:3">
      <div class="box-label">{{ box3.label }}</div>
      <ul class="box-pts">{% for p in box3.points %}<li>{{ p }}</li>{% endfor %}</ul>
    </div>

    <div style="grid-column:2;grid-row:3">
      <div class="box-c">
        <div class="box-label" style="font-size:15px;text-align:center">{{ box4.label }}</div>
        <ul class="box-pts">{% for p in box4.points %}<li style="font-size:12.5px">{{ p }}</li>{% endfor %}</ul>
      </div>
    </div>

    <div class="box" style="grid-column:3;grid-row:3">
      <div class="box-label">{{ box5.label }}</div>
      <ul class="box-pts">{% for p in box5.points %}<li>{{ p }}</li>{% endfor %}</ul>
    </div>

  </div>

  <!-- Bottom deco -->
  <div class="deco-row">
    <div class="lines">
      <div class="ln" style="width:54px"></div>
      <div class="ln" style="width:42px"></div>
      <div class="ln" style="width:30px"></div>
    </div>
    <svg width="74" height="34" viewBox="0 0 74 34" fill="none">
      <polyline points="4,30 14,22 26,26 38,14 52,18 70,4" stroke="#111" stroke-width="2" stroke-linejoin="round"/>
      <polygon points="70,4 63,7 65,13" fill="#111"/>
    </svg>
    <svg width="60" height="34" viewBox="0 0 60 34" fill="none">
      <polyline points="4,28 14,20 26,24 38,12 52,6" stroke="#111" stroke-width="2" stroke-linejoin="round"/>
      <polygon points="52,6 45,9 47,15" fill="#111"/>
    </svg>
    <div class="lines">
      <div class="ln" style="width:30px"></div>
      <div class="ln" style="width:42px"></div>
      <div class="ln" style="width:54px"></div>
    </div>
  </div>

  <!-- Quote -->
  <div class="quote">{{ quote }}</div>

  <!-- Footer -->
  <div class="footer">
    <div class="fi"></div>
    <div class="handle">{{ handle }}</div>
  </div>

  <!-- Pencil deco -->
  <div class="pencil">✏️</div>

</div>

<script>
// Auto-fit: shrink box-label if it overflows
document.querySelectorAll('.box-label').forEach(el => {
  let size = parseFloat(getComputedStyle(el).fontSize);
  while (el.scrollWidth > el.parentElement.clientWidth - 26 && size > 12) {
    size -= 1;
    el.style.fontSize = size + 'px';
  }
});
// Auto-fit: shrink quote if it overflows
const q = document.querySelector('.quote');
let qs = parseFloat(getComputedStyle(q).fontSize);
while (q.scrollHeight > 72 && qs > 12) {
  qs -= 0.5;
  q.style.fontSize = qs + 'px';
}
</script>
</body>
</html>

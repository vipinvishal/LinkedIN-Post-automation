<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;600;700&display=swap" rel="stylesheet">
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { width: 900px; overflow: hidden; }

  .page {
    width: 900px;
    height: 900px;
    background-color: #f3ead4;
    background-image: repeating-linear-gradient(
      to bottom,
      transparent 0px, transparent 28px,
      #adc8e0 28px, #adc8e0 29px
    );
    font-family: 'Caveat', cursive;
    position: relative;
    overflow: hidden;
    border: 5px solid #1a1210;
  }

  /* spiral rings column */
  .rings-col {
    position: absolute; left: 0; top: 0; bottom: 0; width: 56px;
    background: #ece2c2;
    border-right: 3px solid #2a1e1e;
    z-index: 3;
  }
  .ring {
    position: absolute; left: 8px;
    width: 40px; height: 22px;
    border: 3.5px solid #2a1e1e;
    border-radius: 50%;
    border-bottom-color: transparent;
    border-left-color: transparent;
    transform: rotate(-20deg);
  }

  /* content starts after rings */
  .content {
    position: absolute; left: 56px; top: 0; right: 0; bottom: 0;
  }

  /* logo box */
  .logo-box {
    border: 3.5px solid #1a1a1a;
    width: 58px; height: 58px;
    display: flex; align-items: center; justify-content: center;
    font-size: 26px; font-weight: 700; color: #1a1a1a;
    flex-shrink: 0; letter-spacing: -1px;
  }

  /* node label (box with border) */
  .node-label {
    display: inline-block;
    border: 3.5px solid #1a1a1a;
    padding: 5px 16px 4px 16px;
    font-size: 26px; font-weight: 700; color: #1a1a1a;
    letter-spacing: 0.5px;
    background: rgba(243,234,212,0.6);
  }

  /* bullet points outside the box */
  .node-pts {
    list-style: none;
    margin-top: 8px;
    margin-left: 5px;
  }
  .node-pts li {
    font-size: 21px;
    color: #1a1a1a;
    line-height: 1.5;
  }
  .node-pts li::before { content: "• "; }

  /* each node is absolutely positioned */
  .node { position: absolute; }

  /* handle footer */
  .handle { font-size: 20px; color: #555; font-style: italic; }
  .fi {
    width: 27px; height: 27px; border: 2.5px solid #555;
    border-radius: 7px; position: relative; flex-shrink: 0;
  }
  .fi::before {
    content: ''; position: absolute; left: 50%; top: 50%;
    transform: translate(-50%,-50%);
    width: 12px; height: 12px; border: 2px solid #555; border-radius: 50%;
  }
  .fi::after {
    content: ''; position: absolute; right: 4px; top: 4px;
    width: 3px; height: 3px; background: #555; border-radius: 50%;
  }
</style>
</head>
<body>
<div class="page">

  <!-- Rings -->
  <div class="rings-col">
    {% for i in range(14) %}<div class="ring" style="top:{{ 18 + i*62 }}px"></div>{% endfor %}
  </div>

  <!-- SVG overlay: all arrows, icons, decorations -->
  <!-- coordinate origin = page x=56 (same as .content left) -->
  <svg style="position:absolute;left:56px;top:0;pointer-events:none;overflow:visible"
       width="844" height="900" viewBox="0 0 844 900">
    <defs>
      <filter id="rgh" x="-6%" y="-12%" width="112%" height="124%">
        <feTurbulence type="fractalNoise" baseFrequency="0.04" numOctaves="3" result="n" seed="5"/>
        <feDisplacementMap in="SourceGraphic" in2="n" scale="2.2" xChannelSelector="R" yChannelSelector="G"/>
      </filter>
      <marker id="arr" markerWidth="12" markerHeight="8" refX="10" refY="4" orient="auto">
        <polygon points="0 0.5, 10 4, 0 7.5" fill="#1a1a1a"/>
      </marker>
    </defs>

    <!-- ── Long horizontal arrow under header ── -->
    <line x1="20" y1="136" x2="806" y2="136"
          stroke="#1a1a1a" stroke-width="2.5" marker-end="url(#arr)" filter="url(#rgh)"/>

    <!-- ── STRATEGY → lightbulb ── -->
    <line x1="208" y1="172" x2="345" y2="212"
          stroke="#1a1a1a" stroke-width="2.5" marker-end="url(#arr)" filter="url(#rgh)"/>

    <!-- ── Lightbulb → ENGAGEMENT (center node) ── -->
    <line x1="372" y1="256" x2="372" y2="336"
          stroke="#1a1a1a" stroke-width="2.5" marker-end="url(#arr)" filter="url(#rgh)"/>

    <!-- ── NETWORK → ENGAGEMENT (diagonal up-right) ── -->
    <line x1="196" y1="528" x2="284" y2="432"
          stroke="#1a1a1a" stroke-width="2.5" marker-end="url(#arr)" filter="url(#rgh)"/>

    <!-- ── Up arrow left column (NETWORK feeds back to STRATEGY) ── -->
    <line x1="82" y1="496" x2="82" y2="302"
          stroke="#1a1a1a" stroke-width="2.5" marker-end="url(#arr)" filter="url(#rgh)"/>

    <!-- ── ENGAGEMENT → ANALYTICS (diagonal right-down) ── -->
    <line x1="488" y1="420" x2="508" y2="498"
          stroke="#1a1a1a" stroke-width="2.5" marker-end="url(#arr)" filter="url(#rgh)"/>

    <!-- ── CONTENT → ANALYTICS (down) ── -->
    <line x1="625" y1="296" x2="625" y2="494"
          stroke="#1a1a1a" stroke-width="2.5" marker-end="url(#arr)" filter="url(#rgh)"/>

    <!-- ── ENGAGEMENT → down to bottom deco ── -->
    <line x1="372" y1="488" x2="372" y2="656"
          stroke="#1a1a1a" stroke-width="2.5" marker-end="url(#arr)" filter="url(#rgh)"/>

    <!-- ── Lightbulb icon at center (358,196) ── -->
    <g transform="translate(334,178)" filter="url(#rgh)">
      <!-- bulb -->
      <path d="M24 42 C8 36 4 20 4 16 C4 4 12 0 24 0 C36 0 44 4 44 16 C44 20 40 36 24 42Z"
            stroke="#1a1a1a" stroke-width="2.4" fill="none"/>
      <!-- base lines -->
      <line x1="15" y1="44" x2="33" y2="44" stroke="#1a1a1a" stroke-width="2.2"/>
      <line x1="17" y1="50" x2="31" y2="50" stroke="#1a1a1a" stroke-width="2.2"/>
      <path d="M20 56 Q24 62 28 56" stroke="#1a1a1a" stroke-width="2.2" fill="none"/>
      <!-- shine rays -->
      <line x1="24" y1="-4"  x2="24" y2="-12" stroke="#1a1a1a" stroke-width="2"/>
      <line x1="6"  y1="6"   x2="0"  y2="0"   stroke="#1a1a1a" stroke-width="2"/>
      <line x1="42" y1="6"   x2="48" y2="0"   stroke="#1a1a1a" stroke-width="2"/>
    </g>

    <!-- ── Growth bar chart (top-right) ── -->
    <g transform="translate(700,14)" filter="url(#rgh)">
      <rect x="0"  y="52" width="14" height="14" stroke="#1a1a1a" stroke-width="2" fill="none"/>
      <rect x="18" y="40" width="14" height="26" stroke="#1a1a1a" stroke-width="2" fill="none"/>
      <rect x="36" y="26" width="14" height="40" stroke="#1a1a1a" stroke-width="2" fill="none"/>
      <rect x="54" y="12" width="14" height="54" stroke="#1a1a1a" stroke-width="2" fill="none"/>
      <rect x="72" y="0"  width="14" height="66" stroke="#1a1a1a" stroke-width="2" fill="none"/>
      <path d="M4 55 Q38 22 88 6" stroke="#1a1a1a" stroke-width="2.8" fill="none" marker-end="url(#arr)"/>
    </g>

    <!-- ── Pencil decoration (right side, between CONTENT and ANALYTICS) ── -->
    <g transform="translate(762,340) rotate(18)" filter="url(#rgh)">
      <rect x="0" y="0" width="14" height="65" stroke="#1a1a1a" stroke-width="2" fill="none"/>
      <polygon points="0,65 14,65 7,80" stroke="#1a1a1a" stroke-width="2" fill="none"/>
      <line x1="0" y1="10" x2="14" y2="10" stroke="#1a1a1a" stroke-width="2"/>
      <rect x="0" y="0" width="14" height="10" stroke="#1a1a1a" stroke-width="2" fill="none"/>
    </g>

    <!-- ── Deco lines bottom-left ── -->
    <g transform="translate(18,700)" filter="url(#rgh)">
      <line x1="0" y1="0"  x2="60" y2="0"  stroke="#1a1a1a" stroke-width="2.5"/>
      <line x1="0" y1="11" x2="46" y2="11" stroke="#1a1a1a" stroke-width="2.5"/>
      <line x1="0" y1="22" x2="32" y2="22" stroke="#1a1a1a" stroke-width="2.5"/>
    </g>

    <!-- ── Mini growth chart (center-bottom) ── -->
    <g transform="translate(290,662)" filter="url(#rgh)">
      <line x1="0" y1="56" x2="144" y2="56" stroke="#1a1a1a" stroke-width="1.8"/>
      <line x1="0" y1="56" x2="0"   y2="0"  stroke="#1a1a1a" stroke-width="1.8"/>
      <polyline points="5,52 28,40 52,44 78,26 106,28 136,10"
                stroke="#1a1a1a" stroke-width="2.2" fill="none"/>
      <polygon points="136,10 132,18 140,18" fill="#1a1a1a"/>
    </g>

    <!-- ── Mini growth chart (right-bottom) ── -->
    <g transform="translate(510,662)" filter="url(#rgh)">
      <line x1="0" y1="56" x2="130" y2="56" stroke="#1a1a1a" stroke-width="1.8"/>
      <line x1="0" y1="56" x2="0"   y2="0"  stroke="#1a1a1a" stroke-width="1.8"/>
      <polyline points="5,52 30,34 58,38 86,18 118,8"
                stroke="#1a1a1a" stroke-width="2.2" fill="none"/>
      <polygon points="118,8 114,16 122,16" fill="#1a1a1a"/>
    </g>

    <!-- ── Deco lines bottom-right ── -->
    <g transform="translate(724,700)" filter="url(#rgh)">
      <line x1="0" y1="0"  x2="-60" y2="0"  stroke="#1a1a1a" stroke-width="2.5"/>
      <line x1="0" y1="11" x2="-46" y2="11" stroke="#1a1a1a" stroke-width="2.5"/>
      <line x1="0" y1="22" x2="-32" y2="22" stroke="#1a1a1a" stroke-width="2.5"/>
    </g>

  </svg>

  <!-- ── HTML text content ── -->
  <div class="content">

    <!-- Header -->
    <div style="position:absolute;left:18px;top:18px;display:flex;align-items:center;gap:16px">
      <div class="logo-box">in</div>
      <div>
        <div style="font-size:44px;font-weight:700;color:#1a1a1a;line-height:1.0;letter-spacing:0.3px">{{ title_line1 }}</div>
        <div style="font-size:44px;font-weight:700;color:#1a1a1a;line-height:1.0;letter-spacing:0.3px">{{ title_line2 }}</div>
      </div>
    </div>

    <!-- TOP-LEFT: box1 -->
    <div class="node" style="left:18px;top:148px">
      <div class="node-label">{{ box1.label }}</div>
      <ul class="node-pts">{% for p in box1.points %}<li>{{ p }}</li>{% endfor %}</ul>
    </div>

    <!-- TOP-RIGHT: box2 -->
    <div class="node" style="left:500px;top:148px">
      <div class="node-label">{{ box2.label }}</div>
      <ul class="node-pts">{% for p in box2.points %}<li>{{ p }}</li>{% endfor %}</ul>
    </div>

    <!-- CENTER: box4 (ENGAGEMENT-equivalent) -->
    <div class="node" style="left:268px;top:338px">
      <div class="node-label">{{ box4.label }}</div>
      <ul class="node-pts">{% for p in box4.points %}<li>{{ p }}</li>{% endfor %}</ul>
    </div>

    <!-- BOTTOM-LEFT: box3 -->
    <div class="node" style="left:18px;top:500px">
      <div class="node-label">{{ box3.label }}</div>
      <ul class="node-pts">{% for p in box3.points %}<li>{{ p }}</li>{% endfor %}</ul>
    </div>

    <!-- BOTTOM-RIGHT: box5 -->
    <div class="node" style="left:500px;top:500px">
      <div class="node-label">{{ box5.label }}</div>
      <ul class="node-pts">{% for p in box5.points %}<li>{{ p }}</li>{% endfor %}</ul>
    </div>

    <!-- Footer -->
    <div style="position:absolute;bottom:16px;right:18px;display:flex;align-items:center;gap:8px">
      <div class="fi"></div>
      <span class="handle">{{ handle }}</span>
    </div>

  </div>

</div>

<script>
document.querySelectorAll('.node-label').forEach(el => {
  let sz = parseFloat(getComputedStyle(el).fontSize);
  while (el.scrollWidth > el.parentElement.clientWidth - 4 && sz > 14) {
    sz -= 1; el.style.fontSize = sz + 'px';
  }
});
</script>
</body>
</html>
